# Copy to .env and adjust. All values are optional for the local `rtb demo` path
# (which uses the in-memory store + hashing embedder and needs none of these).

# --- Secrets / external services (only needed for the docker-compose / real-infra path) ---
POSTGRES_DSN=postgresql+asyncpg://rtb:rtb@localhost:5432/rtb
REDIS_URL=redis://localhost:6379/0

# --- Override any config.yaml field via RTB__SECTION__FIELD ---
# RTB__STORE__FEATURE_BACKEND=postgres
# RTB__STORE__CACHE_BACKEND=redis
# RTB__EMBEDDINGS__PROVIDER=local
# RTB__RETRAIN__INTERVAL_HOURS=6

# --- API embeddings (only when RTB__EMBEDDINGS__PROVIDER=api) ---
# OPENAI_API_KEY=sk-...
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa.json
# RTB_CONFIG_FILE=configs/config.yaml
